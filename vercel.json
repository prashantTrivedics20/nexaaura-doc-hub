{
  "version": 2,
  "builds": [
    {
      "src": "frontend-new/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend-new/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "https://your-backend-url.onrender.com"
  },
  "buildCommand": "cd frontend-new && npm run build",
  "outputDirectory": "frontend-new/dist",
  "installCommand": "cd frontend-new && npm install"
}